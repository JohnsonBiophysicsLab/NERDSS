# Input file

start parameters
    nItr = 1000000
    timeStep = 0.2
    timeWrite = 100
    trajWrite = 1000000
    pdbWrite = 1000
    restartWrite = 10000
end parameters

start boundaries
    WaterBox = [939.993,939.993,139.993]
end boundaries

start molecules  
    IL : 6000
    A  : 10
end molecules

start reactions
    ### A+IL
    A(a) + IL(m) <-> A(a!1).IL(m!1)
    onRate3Dka  = 10000000  #ka in nm3/us: kon = 3E7   M-1s-1
    offRatekb   = 0 #kb in /s
    sigma       = 1  #nm
    norm1       = [0,0,1]
    norm2       = [0,0,1]
    #lipids are normal to membrane plane, so M has theta value,
    assocAngles = [M_PI, M_PI, nan, nan, nan]
end reactions
