 # Input file

start parameters
    nItr = 1e9
    timestep = 0.3
    timeWrite = 5000
    trajWrite = 1000000
    restartWrite = 1000000
    fromRestart = false
    overlapSepLimit = 2.3
    scaleMaxDisplace = 30.0
    pdbWrite = 1000000
    transitionWrite = 5000
end parameters

start boundaries
    WaterBox = [321.47, 321.47, 321.47] #nm
    implicitLipid = false
    xBCtype = reflect
    yBCtype = reflect
    zBCtype = reflect
end boundaries

start molecules
     A:1000
end molecules

start reactions
    
    #### A - C (Trimer) ####
    A(c) + A(q) <-> A(c!1).A(q!1)
    onRate3Dka = 10.0000
    offRatekb = 10002.8000
    sigma = 0.729108
    norm1 = [-0.051846,-0.002660,0.998652]
    norm2 = [-0.051846,-0.002660,0.998652]
    assocAngles = [2.664786,2.493340,0.333380,-0.238772,-0.089999]
    loopCoopFactor = 1 


end reactions