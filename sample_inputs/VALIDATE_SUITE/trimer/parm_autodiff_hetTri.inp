# Input file

start parameters
    nItr = 5E5 #iterations
    timeStep = 0.3 #in us
    timeWrite = 1000
    trajWrite = 100000
	pdbWrite = 100000
    restartWrite = 1000000
    checkPoint = 5000000
	scaleMaxDisplace = 10.0	
    overlapSepLimit = 1.0
end parameters

start boundaries
    WaterBox = [118.41,118.41,118.41] #nm, for 100uM
end boundaries

start molecules
    A : 100
    B : 100
    C : 100
end molecules

start reactions
	    
    #Same sites - Dimer reactions
    A(a1) + B(b2) <-> A(a1!1).B(b2!1)
    onRate3DMacro = 10.0  #ka
    offRatekb = 16615.0 #kb
    norm1 = [0, 4.17774579, -6.75973469]
    norm2 = [0, 4.17774579, -6.75973469]
    sigma = 1.0
    assocAngles = [2.58801829,2.58801829,0,0,0]
    bindRadSameCom = 1.5
    loopCoopFactor = 1.0
    

    A(a2) + C(c1) <-> A(a2!1).C(c1!1)
    onRate3DMacro = 10.0  #ka
    offRatekb = 16615.0 #kb
    norm1 = [0, 4.17774579, -6.75973469]
    norm2 = [0, 4.17774579, -6.75973469]
    sigma = 1.0
    assocAngles = [2.58801829,2.58801829,0,0,0]
    bindRadSameCom = 1.5
    loopCoopFactor = 1.0
    

    C(c2) + B(b1) <-> C(c2!1).B(b1!1)
    onRate3DMacro = 10.0  #ka
    offRatekb = 16615.0  #kb
    norm1 = [0, 4.17774579, -6.75973469]
    norm2 = [0, 4.17774579, -6.75973469]
    sigma = 1.0
    assocAngles = [2.58801829,2.58801829,0,0,0]
    bindRadSameCom = 1.5
    loopCoopFactor = 1.0
end reactions
