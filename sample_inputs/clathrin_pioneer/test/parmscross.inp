# Input file

start parameters
    nItr = 500000000
    timeStep = 3

    timeWrite = 50000
    trajWrite = 500000000
    pdbWrite = 5000000
    transitionWrite = 3000000
    restartWrite = 50000
    checkPoint = 5000000
    scaleMaxDisplace = 10.0
    overlapSepLimit = 7.0
    clusterOverlapCheck = false
end parameters

start boundaries
    WaterBox = [700,700,1000]
    xBCtype = reflect
    yBCtype = reflect
    zBCtype = reflect
end boundaries

start molecules
    p : 10000
    f : 13 #0.042uM
    e : 28 #0.094uM
    ap2 : 59 #0.2uM
    clat : 192 #0.65uM
end molecules

start reactions
    #### pip2 - FCHo1/2 ####
    f(fl) + p(head) <-> f(fl!1).p(head!1)
    onRate3DMacro = 1.4
    offRateMacro = 1
    sigma = 1.0
    bindRadSameCom = 1.1
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    assocAngles = [1.5707963, 1.5707963, nan, nan, M_PI]
    observeLabel = fp

    #### FCHo1/2 - FCHo1/2 ####
    f(ff) + f(ff) <-> f(ff!1).f(ff!1)
    onRate3DMacro = 0.4
    offRateMacro = 1
    sigma = 1.0
    bindRadSameCom = 1.1
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [M_PI,M_PI,nan,nan,0]
    observeLabel = ff

    #### CC - CC ####
    e(cc) + e(cc) <-> e(cc!1).e(cc!1)
    onRate3DMacro = 7.9
    offRateMacro = 1
    sigma = 1.0
    bindRadSameCom = 1.1
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [2.3561945, 2.3561945, 1.5707963, 1.5707963, 0]
    observeLabel = ee

    #### EH - unstructured region ####
    e(eh,cc!*,ee) + e(ee,cc!*,eh) <-> e(eh!1,cc!*,ee).e(ee!1,cc!*,eh)
    onRate3DMacro = 0.1
    offRateMacro = 1
    sigma = 1.0
    bindRadSameCom = 4
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [1.5708024, 1.5708024, 1.5707963, 1.5707963, 0]
    observeLabel = tt

    e(eh) + e(ee) <-> e(eh!1).e(ee!1)
    onRate3DMacro = 0
    offRateMacro = 1

    #### EH - uHD ####
    e(ef) + f(fu) <-> e(ef!1).f(fu!1)
    onRate3DMacro = 0.37
    offRateMacro = 1
    sigma = 1.0
    bindRadSameCom = 1.1
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [3.1415831, 1.5707963, M_PI, nan, M_PI]
    observeLabel = ef

    #### pip2 - AP2 ####
    ap2(m2muh) + p(head) <-> ap2(m2muh!1).p(head!1)
    onRate3DMacro = 0.333
    offRateMacro = 1
    sigma = 1.0
    bindRadSameCom = 1.1
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [1.5707963, 1.5707963, nan, nan, M_PI]
    observeLabel = ap

    #### eps15 - AP2 ####
    ap2(ae) + e(ea) <-> ap2(ae!1).e(ea!1)
    onRate3DMacro = 0.1
    offRateMacro = 1
    sigma = 1.0
    bindRadSameCom = 1.1
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [1.5707963, 3.1415852, nan, M_PI, M_PI]
    observeLabel = ae

    #### AP2 - CLAT ####
    ##only binds to clathrin if it is on the membrane
    ap2(b2clat,m2muh!*) + clat(td1) <-> ap2(b2clat!1,m2muh!*).clat(td1!1)
    onRate3DMacro = 0.0012
    offRateMacro = 0.03
    sigma = 1.0
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [1.5707963, 2.466852, nan, pi, pi]

    ap2(b2clat,m2muh!*) + clat(td2) <-> ap2(b2clat!1,m2muh!*).clat(td2!1)
    onRate3DMacro = 0.0012
    offRateMacro = 0.03
    sigma = 1.0
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [1.5707963, 2.466852, nan, pi, pi]

    ap2(b2clat,m2muh!*) + clat(td3) <-> ap2(b2clat!1,m2muh!*).clat(td3!1)
    onRate3DMacro = 0.0012
    offRateMacro = 0.03
    sigma = 1.0
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [1.5707963, 2.466852, nan, pi, pi]

    ##only binds to clathrin if it is on the membrane, unbinds always!
    ap2(b2clat) + clat(td1) <-> ap2(b2clat!1).clat(td1!1)
    onRate3DMacro = 0
    offRateMacro = 0.03
    sigma = 1.0
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [1.5707963, 2.466852, nan, pi, pi]

    ap2(b2clat) + clat(td2) <-> ap2(b2clat!1).clat(td2!1)
    onRate3DMacro = 0
    offRateMacro = 0.03
    sigma = 1.0
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [1.5707963, 2.466852, nan, pi, pi]

    ap2(b2clat) + clat(td3) <-> ap2(b2clat!1).clat(td3!1)
    onRate3DMacro = 0
    offRateMacro = 0.03
    sigma = 1.0
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    length3Dto2D = 30 # in nm
    assocAngles = [1.5707963, 2.466852, nan, pi, pi]

    ### CLAT - CLAT IN SOLUTION###
    clat(cd1,td1,td2,td3) + clat(cd2,td1,td2,td3) <-> clat(cd1!1,td1,td2,td3).clat(cd2!1,td1,td2,td3)
    onRate3DMacro = 0.167
    offRateMacro = 10
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    sigma = 5.0
    bindRadSameCom = 1.1
    loopCoopFactor = 0.001
    length3Dto2D = 30 # in nm
    assocAngles = [M_PI,M_PI,nan,nan,0]
    observeLabel = leg

    clat(cd1,td1,td2,td3) + clat(cd3,td1,td2,td3) <-> clat(cd1!1,td1,td2,td3).clat(cd3!1,td1,td2,td3)
    onRate3DMacro = 0.167
    offRateMacro = 10
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    sigma = 5.0
    bindRadSameCom = 1.1
    loopCoopFactor = 0.001
    length3Dto2D = 30 # in nm
    assocAngles = [M_PI,M_PI,nan,nan,0]
    observeLabel = leg

    clat(cd2,td1,td2,td3) + clat(cd3,td1,td2,td3) <-> clat(cd2!1,td1,td2,td3).clat(cd3!1,td1,td2,td3)
    onRate3DMacro = 0.167
    offRateMacro = 10
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    sigma = 5.0
    bindRadSameCom = 1.1
    loopCoopFactor = 0.001
    length3Dto2D = 30 # in nm
    assocAngles = [M_PI,M_PI,nan,nan,0]
    observeLabel = leg

    clat(cd1,td1,td2,td3) + clat(cd1,td1,td2,td3) <-> clat(cd1!1,td1,td2,td3).clat(cd1!1,td1,td2,td3)
    onRate3DMacro = 0.083
    offRateMacro = 10
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    sigma = 5.0
    bindRadSameCom = 1.1
    loopCoopFactor = 0.001
    length3Dto2D = 30 # in nm
    assocAngles = [M_PI,M_PI,nan,nan,0]
    observeLabel = leg

    clat(cd2,td1,td2,td3) + clat(cd2,td1,td2,td3) <-> clat(cd2!1,td1,td2,td3).clat(cd2!1,td1,td2,td3)
    onRate3DMacro = 0.083
    offRateMacro = 10
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    sigma = 5.0
    bindRadSameCom = 1.1
    loopCoopFactor = 0.001
    length3Dto2D = 30 # in nm
    assocAngles = [M_PI,M_PI,nan,nan,0]
    observeLabel = leg

    clat(cd3,td1,td2,td3) + clat(cd3,td1,td2,td3) <-> clat(cd3!1,td1,td2,td3).clat(cd3!1,td1,td2,td3)
    onRate3DMacro = 0.083
    offRateMacro = 10
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    sigma = 5.0
    bindRadSameCom = 1.1
    loopCoopFactor = 0.001
    length3Dto2D = 30 # in nm
    assocAngles = [M_PI,M_PI,nan,nan,0]
    observeLabel = leg

    #prevent overlap when all sites are bound, via COM.
    clat(ref) + clat(ref) <-> clat(ref!1).clat(ref!1)
    onRate3DMacro = 0
    offRateMacro = 10
    norm1 = [0,0,1]
    norm2 = [0,0,1]
    sigma = 10.0
    bindRadSameCom = 0.5
    assocAngles = [M_PI,M_PI,nan,nan,0]

    #CLAT-CLAT, AT LEAST ONE HAD An AP-2 BOUND
    #1+2
    clat(cd1,td1!*) + clat(cd2) <-> clat(cd1!1,td1!*).clat(cd2!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd1,td2!*) + clat(cd2) <-> clat(cd1!1,td2!*).clat(cd2!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd1,td3!*) + clat(cd2) <-> clat(cd1!1,td3!*).clat(cd2!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    #2+1
    clat(cd2,td1!*) + clat(cd1) <-> clat(cd2!1,td1!*).clat(cd1!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd2,td2!*) + clat(cd1) <-> clat(cd2!1,td2!*).clat(cd1!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd2,td3!*) + clat(cd1) <-> clat(cd2!1,td3!*).clat(cd1!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    #1+3
    clat(cd1,td1!*) + clat(cd3) <-> clat(cd1!1,td1!*).clat(cd3!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd1,td2!*) + clat(cd3) <-> clat(cd1!1,td2!*).clat(cd3!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd1,td3!*) + clat(cd3) <-> clat(cd1!1,td3!*).clat(cd3!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    #3+1
    clat(cd3,td1!*) + clat(cd1) <-> clat(cd3!1,td1!*).clat(cd1!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd3,td2!*) + clat(cd1) <-> clat(cd3!1,td2!*).clat(cd1!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd3,td3!*) + clat(cd1) <-> clat(cd3!1,td3!*).clat(cd1!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    #2+3
    clat(cd2,td1!*) + clat(cd3) <-> clat(cd2!1,td1!*).clat(cd3!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd2,td2!*) + clat(cd3) <-> clat(cd2!1,td2!*).clat(cd3!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd2,td3!*) + clat(cd3) <-> clat(cd2!1,td3!*).clat(cd3!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    #3+2
    clat(cd3,td1!*) + clat(cd2) <-> clat(cd3!1,td1!*).clat(cd2!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd3,td2!*) + clat(cd2) <-> clat(cd3!1,td2!*).clat(cd2!1)
    onRate3DMacro = 1.818
    offRateMacro = 10

    clat(cd3,td3!*) + clat(cd2) <-> clat(cd3!1,td3!*).clat(cd2!1)
    onRate3DMacro = 1.818
    offRateMacro = 10


    #2+2
    clat(cd2,td1!*) + clat(cd2) <-> clat(cd2!1,td1!*).clat(cd2!1)
    onRate3DMacro = 0.917
    offRateMacro = 10

    clat(cd2,td2!*) + clat(cd2) <-> clat(cd2!1,td2!*).clat(cd2!1)
    onRate3DMacro = 0.917
    offRateMacro = 10

    clat(cd2,td3!*) + clat(cd2) <-> clat(cd2!1,td3!*).clat(cd2!1)
    onRate3DMacro = 0.917
    offRateMacro = 10

    #1+1
    clat(cd1,td1!*) + clat(cd1) <-> clat(cd1!1,td1!*).clat(cd1!1)
    onRate3DMacro = 0.917
    offRateMacro = 10

    clat(cd1,td2!*) + clat(cd1) <-> clat(cd1!1,td2!*).clat(cd1!1)
    onRate3DMacro = 0.917
    offRateMacro = 10

    clat(cd1,td3!*) + clat(cd1) <-> clat(cd1!1,td3!*).clat(cd1!1)
    onRate3DMacro = 0.917
    offRateMacro = 10

    #3+3
    clat(cd3,td1!*) + clat(cd3) <-> clat(cd3!1,td1!*).clat(cd3!1)
    onRate3DMacro = 0.917
    offRateMacro = 10

    clat(cd3,td2!*) + clat(cd3) <-> clat(cd3!1,td2!*).clat(cd3!1)
    onRate3DMacro = 0.917
    offRateMacro = 10

    clat(cd3,td3!*) + clat(cd3) <-> clat(cd3!1,td3!*).clat(cd3!1)
    onRate3DMacro = 0.917
    offRateMacro = 10
end reactions
